@model IEnumerable<Ezz_Store.PL.ViewModels.AdminOrderListVM>
@{
    ViewData["Title"] = "Admin Orders";
}

<h2 class="section-title">Orders Management</h2>

<div class="glass-panel p-3">
    <table class="table table-dark table-borderless align-middle">
        <thead>
            <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Status</th>
                <th>Total</th>
                <th>Update</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.OrderNumber</td>
                    <td>@order.CustomerName</td>
                    <td>@order.OrderDate.ToLocalTime().ToString("g")</td>
                    <td><span class="status-badge">@order.Status</span></td>
                    <td>@order.TotalAmount.ToString("C")</td>
                    <td>
                        <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="OrderId" value="@order.Id" />
                            <select name="Status" class="form-select form-select-sm">
                                <option value="pending">pending</option>
                                <option value="accepted">accepted</option>
                                <option value="rejected">rejected</option>
                            </select>
                            <button class="btn btn-sm btn-brand" type="submit">Save</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>