@model Ezz_Store.PL.ViewModels.ProductDetailsVM
@{
    ViewData["Title"] = "Product Details";
}

<div class="glass-panel product-details">
    <div>
        <p class="eyebrow">@Model.CategoryName</p>
        <h2>@Model.Name</h2>
        <p class="muted">SKU: @Model.SKU</p>
    </div>
    <div class="product-detail-meta">
        <p class="price">@Model.Price.ToString("C")</p>
        <p class="muted">Stock: @Model.StockQuantity</p>
        <form asp-controller="Cart" asp-action="Add" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productId" value="@Model.Id" />
            <button class="btn btn-brand" type="submit" @(Model.StockQuantity <= 0 ? "disabled" : null)>Add to
                Cart</button>
                <a class="btn btn-ghost ms-2" asp-controller="Catalog" asp-action="Index">Back</a>
            </form>
        </div>
    </div>